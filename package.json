{
  "name": "ng-whiteboard",
  "version": "5.6.0",
  "license": "MIT",
  "scripts": {
    "ng": "nx",
    "start": "nx serve demo",
    "copy:readme": "copyfiles ./README.md ./projects/ng-whiteboard",
    "build": "npm run build:lib && npm run build:demo",
    "build:lib": "yarn copy:readme && nx build ng-whiteboard --prod",
    "build:demo": "nx build demo --prod --base-href='https://mostafazke.github.io/ng-whiteboard/'",
    "format:check": "nx format:check",
    "format:write": "nx format:write",
    "test": "yarn test:lib && yarn test:demo",
    "test:ci": "nx test ng-whiteboard  --configuration=ci",
    "test:lib": "nx test ng-whiteboard --codeCoverage --watchAll",
    "test:demo": "nx test demo --codeCoverage --watchAll",
    "report-coverage:lib": "cat ./coverage/ng-whiteboard/lcov.info | codecov",
    "publish:demo": "npx angular-cli-ghpages --dir=./dist/demo",
    "publish:lib": "npx semantic-release",
    "adjust-version": "concurrently \"yarn:adjust-version:*\"",
    "adjust-version:lib": "replace-json-property projects/ng-whiteboard/package.json version $VERSION",
    "adjust-version:main": "replace-json-property package.json version $VERSION",
    "semantic-release": "semantic-release",
    "cm": "npx git-cz"
  },
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@angular/service-worker": "20.3.25",
    "firebase": "11.10.0",
    "highlight.js": "~11.11.0",
    "ngx-colors": "^3.6.0",
    "rxjs": "~7.8.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.29",
    "@angular-devkit/core": "^20.3.29",
    "@angular-devkit/schematics": "~20.3.29",
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/build": "20.3.29",
    "@angular/cli": "^20.3.29",
    "@angular/compiler-cli": "20.3.25",
    "@angular/language-service": "20.3.25",
    "@angular/pwa": "~20.3.29",
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "21.6.9",
    "@nx/cypress": "21.6.9",
    "@nx/eslint": "21.6.9",
    "@nx/eslint-plugin": "21.6.9",
    "@nx/jest": "21.6.9",
    "@nx/js": "21.6.9",
    "@nx/web": "21.6.9",
    "@nx/workspace": "21.6.9",
    "@schematics/angular": "~20.3.29",
    "@semantic-release/changelog": "~6.0.3",
    "@semantic-release/commit-analyzer": "~13.0.0",
    "@semantic-release/exec": "~6.0.3",
    "@semantic-release/git": "~10.0.1",
    "@semantic-release/github": "~11.0.1",
    "@semantic-release/npm": "~12.0.1",
    "@semantic-release/release-notes-generator": "~14.1.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.41",
    "@swc/helpers": "~0.5.23",
    "@theunderscorer/nx-semantic-release": "2.12.0",
    "@types/jest": "^30.0.0",
    "@types/node": "18.16.9",
    "@typescript-eslint/utils": "8.61.1",
    "angular-eslint": "^20.7.0",
    "autoprefixer": "^10.5.0",
    "canvas": "^3.2.3",
    "codecov": "^3.8.3",
    "concurrently": "9.1.0",
    "copyfiles": "2.4.1",
    "cypress": "14.5.4",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "^3.5.0",
    "git-cz": "4.9.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^17.0.0",
    "jsonc-eslint-parser": "^2.1.0",
    "ng-packagr": "^20.3.2",
    "nx": "21.6.9",
    "postcss": "^8.4.5",
    "postcss-url": "~10.1.4",
    "prettier": "^2.6.2",
    "replace-json-property": "^1.9.0",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "8.61.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mostafazke/ng-whiteboard.git"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/git-cz"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
